# ============================================================
# UK LINEN HOUSE — Environment variables
# Copy this file to ".env.local" and fill in real values.
# ============================================================

# MongoDB connection string (from MongoDB Atlas or local)
MONGODB_URI="mongodb://127.0.0.1:27017/uk-linen-house"

# Secret used to sign admin login tokens (use a long random string)
JWT_SECRET="change-this-to-a-long-random-secret"

# Admin seed credentials (used by the create-admin script)
ADMIN_EMAIL="admin@uklinenhouse.co.uk"
ADMIN_PASSWORD="ChangeMe123!"

# Stripe keys (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Public site URL (used for Stripe redirects)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
